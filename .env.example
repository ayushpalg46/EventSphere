# EventSphere Configuration Settings
# Copy this file to .env and configure the variables.

PORT=3000
SESSION_SECRET=eventsphere_production_secure_session_secret_key

# PostgreSQL Connection URL
DATABASE_URL=

# Razorpay Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google Gemini API Key
GEMINI_API_KEY=

# Email SMTP Settings
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM="EventSphere Support" <tickets@yourdomain.com>
EMAIL_USER=
EMAIL_PASS=
