# EventSphere Configuration Settings
# Copy this file to .env and configure the variables.

# Server Port
PORT=3000

# Express Session Secret
SESSION_SECRET=eventsphere_hackathon_super_secret_session_key_123

# Database path (optional, defaults to ./database/eventsphere.db)
# On Render, if you mount a persistent disk at /data, set this to: /data/eventsphere.db
DB_PATH=./database/eventsphere.db

# Razorpay Sandbox Keys (test mode - dummy for now)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google Gemini API Key for AI copywriting and scheduling helpers
# If left empty, the application will automatically fall back to built-in templates
GEMINI_API_KEY=

# Email Configuration (Optional - fallback to simulator writes under scratch/simulated_emails/)
# To send real physical emails:
# - For Gmail: Leave EMAIL_HOST empty, set EMAIL_USER to your Gmail and EMAIL_PASS to your 16-character App Password.
# - For SendGrid: Set EMAIL_HOST=smtp.sendgrid.net, EMAIL_PORT=587, EMAIL_SECURE=false, EMAIL_USER=apikey, EMAIL_PASS=your_sendgrid_api_key.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM="EventSphere Support" <tickets@yourdomain.com>
EMAIL_USER=
EMAIL_PASS=

# PostgreSQL Database Connection URL (Supabase or direct PG connection)
DATABASE_URL=
