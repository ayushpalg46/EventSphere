<%- include('partials/header') %>

<!-- Hero Banner Section -->
<section class="hero">
  <div class="hero-content">
    <h1>Don't Just Live. Experience.</h1>
    <p>Discover and book tickets for the best music festivals, standup comedy, tech hackathons, and local events around you.</p>
    
    <!-- Home Search Bar -->
    <form action="/events" method="GET" class="search-container">
      <div class="search-input-group">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" name="search" placeholder="Search by event name, artists, tags...">
      </div>
      
      <select name="city" class="search-select">
        <option value="">Select City</option>
        <option value="Online">Online / Virtual</option>
        <% cities.forEach(city => { %>
          <option value="<%= city %>"><%= city %></option>
        <% }) %>
      </select>
      
      <button type="submit" class="btn btn-primary"><i class="fa-solid fa-arrow-right-to-bracket"></i> Find</button>
    </form>
  </div>
</section>

<main class="container">
  
  <!-- Browse Categories Shortcut Row -->
  <section>
    <div class="section-header">
      <h2>Explore by Category</h2>
    </div>
    <div class="category-container">
      <a href="/events?category=Music" class="category-card" data-tilt data-tilt-scale="1.04">
        <i class="fa-solid fa-music"></i>
        <h3>Concerts & Music</h3>
      </a>
      <a href="/events?category=Comedy" class="category-card" data-tilt data-tilt-scale="1.04">
        <i class="fa-solid fa-face-laugh-beam"></i>
        <h3>Comedy Shows</h3>
      </a>
      <a href="/events?category=Tech" class="category-card" data-tilt data-tilt-scale="1.04">
        <i class="fa-solid fa-laptop-code"></i>
        <h3>Hackathons & Tech</h3>
      </a>
      <a href="/events?category=Movies" class="category-card" data-tilt data-tilt-scale="1.04">
        <i class="fa-solid fa-film"></i>
        <h3>Movies & Theatre</h3>
      </a>
    </div>
  </section>

  <!-- Featured Upcoming Events List -->
  <section style="margin-bottom: 60px;">
    <div class="section-header">
      <h2>Featured Upcoming Events</h2>
      <a href="/events" class="btn btn-secondary">View All <i class="fa-solid fa-circle-arrow-right"></i></a>
    </div>
    
    <div class="event-grid">
      <% if (featuredEvents && featuredEvents.length > 0) { %>
        <% featuredEvents.forEach(event => { %>
          <div class="event-card" data-tilt>
            <div class="event-banner-wrap">
              <span class="event-category-tag"><%= event.category %></span>
              <%
                let fallbackImage = 'https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?w=600';
                if (event.category === 'Music') fallbackImage = 'https://images.unsplash.com/photo-1506157786151-b8491531f063?w=600';
                else if (event.category === 'Comedy') fallbackImage = 'https://images.unsplash.com/photo-1585647347483-22b66260dfff?w=600';
                else if (event.category === 'Tech') fallbackImage = 'https://images.unsplash.com/photo-1515879218367-8466d910aaa4?w=600';
                else if (event.category === 'Movies') fallbackImage = 'https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=600';
              %>
              <img src="<%= String(event.banner_image).startsWith('data:') ? event.banner_image : '/uploads/' + event.banner_image %>" alt="<%= event.title %>" onerror="this.src='<%= fallbackImage %>'">
            </div>
            
            <div class="event-card-body">
              <h3><%= event.title %></h3>
              
              <div class="event-info-row">
                <i class="fa-solid fa-calendar-day"></i>
                <span><%= new Date(event.start_date).toLocaleDateString('en-IN', { weekday: 'short', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
              </div>
              
              <div class="event-info-row">
                <i class="fa-solid fa-location-dot"></i>
                <span><%= event.venue_name %>, <%= event.city %></span>
              </div>
              
              <div class="event-price-info">
                <div>
                  <p class="price-lbl">Tickets From</p>
                  <p class="price-val">
                    <% if (event.minPrice === 0) { %>
                      Free
                    <% } else if (event.minPrice) { %>
                      Rs. <%= event.minPrice %>
                    <% } else { %>
                      Rs. 0
                    <% } %>
                  </p>
                </div>
                <a href="/events/<%= event.id %>" class="btn btn-primary" style="padding: 6px 14px; font-size: 0.85rem;">Details</a>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p style="grid-column: 1/-1; text-align: center; color: var(--text-muted); padding: 40px;">No events are currently scheduled. Please check back later!</p>
      <% } %>
    </div>
  </section>

</main>

<%- include('partials/footer') %>
