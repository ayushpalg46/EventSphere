<!-- views/partials/sidebar.ejs -->
<div class="dashboard-sidebar">
  <div style="text-align: center; margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid var(--border-color);">
    <div class="profile-avatar-large" style="margin: 0 auto 12px auto; width: 70px; height: 70px; font-size: 2rem;">
      <%= user.name.charAt(0) %>
    </div>
    <h3 style="font-size: 1.1rem; font-weight: 600;"><%= user.name %></h3>
    <p style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; margin-top: 4px;"><%= user.role %> Account</p>
    <p style="font-size: 0.8rem; color: var(--accent-color); margin-top: 4px;"><i class="fa-solid fa-arrows-spin"></i> Visits: <%= user.visit_count || 1 %></p>
  </div>

  <% if (user.role === 'organiser') { %>
    <p class="sidebar-heading">Organiser Dashboard</p>
    <ul class="sidebar-menu">
      <li>
        <a href="/organiser/dashboard" class="sidebar-link">
          <i class="fa-solid fa-chart-line"></i> Dashboard Stats
        </a>
      </li>
      <li>
        <a href="/organiser/create-event" class="sidebar-link">
          <i class="fa-solid fa-plus-circle"></i> Create Event
        </a>
      </li>
      <li>
        <a href="/organiser/refunds" class="sidebar-link">
          <i class="fa-solid fa-reply-all"></i> Refund Requests
        </a>
      </li>
      <li>
        <a href="/user/profile" class="sidebar-link">
          <i class="fa-solid fa-user-gear"></i> Edit Profile
        </a>
      </li>
    </ul>
  <% } else { %>
    <p class="sidebar-heading">Attendee Dashboard</p>
    <ul class="sidebar-menu">
      <li>
        <a href="/user/dashboard" class="sidebar-link">
          <i class="fa-solid fa-ticket"></i> Bookings & Tickets
        </a>
      </li>
      <li>
        <a href="/user/profile" class="sidebar-link">
          <i class="fa-solid fa-user-gear"></i> Profile & Address
        </a>
      </li>
      <li>
        <a href="/help" class="sidebar-link">
          <i class="fa-solid fa-circle-question"></i> Help Centre
        </a>
      </li>
    </ul>
  <% } %>

  <div style="margin-top: auto; padding-top: 20px; border-top: 1px solid var(--border-color); text-align: center;">
    <a href="/logout" class="btn btn-secondary" style="width: 100%; font-size: 0.85rem; padding: 8px;"><i class="fa-solid fa-sign-out-alt"></i> Logout</a>
  </div>
</div>
