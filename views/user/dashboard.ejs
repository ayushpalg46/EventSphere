<%- include('../partials/header') %>

<main class="container">
  
  <div class="dashboard-layout">
    
    <!-- Left Column: Sidebar -->
    <%- include('../partials/sidebar') %>
    
    <!-- Right Column: Panel Content -->
    <div class="dashboard-content">
      
      <div class="dashboard-title-row">
        <h1>Attendee Dashboard</h1>
      </div>

      <!-- Success Banners -->
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success">
          <i class="fa-solid fa-circle-check"></i> <%= success %>
        </div>
      <% } %>

      <!-- Section: Tickets -->
      <div class="dashboard-card">
        <h3 class="dashboard-card-title"><i class="fa-solid fa-receipt" style="color: var(--accent-color);"></i> My Bookings & Tickets</h3>
        
        <% if (bookings && bookings.length > 0) { %>
          <div class="table-responsive">
            <table class="dashboard-table">
              <thead>
                <tr>
                  <th>Booking ID</th>
                  <th>Event Name</th>
                  <th>Ticket Tier</th>
                  <th>Quantity</th>
                  <th>Paid (Rs)</th>
                  <th>Check-in Status</th>
                  <th>Payment Status</th>
                  <th style="text-align: right;">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% bookings.forEach(booking => { %>
                  <tr>
                    <td>#ES-<%= booking.booking_id %></td>
                    <td>
                      <strong><%= booking.event_title %></strong>
                      <br />
                      <span style="font-size: 0.8rem; color: var(--text-muted);"><%= new Date(booking.start_date).toLocaleDateString('en-IN') %></span>
                    </td>
                    <td><%= booking.ticket_name %></td>
                    <td><%= booking.quantity %></td>
                    <td>Rs. <%= booking.total_amount %></td>
                    <td>
                      <% if (booking.checked_in) { %>
                        <span class="badge badge-paid"><i class="fa-solid fa-circle-check"></i> Checked-In</span>
                      <% } else { %>
                        <span class="badge badge-pending"><i class="fa-solid fa-clock"></i> Not Checked-In</span>
                      <% } %>
                    </td>
                    <td>
                      <span class="badge badge-<%= booking.payment_status %>"><%= booking.payment_status.toUpperCase() %></span>
                      <% if (booking.refund_status !== 'none') { %>
                        <br /><span style="font-size: 0.75rem; color: var(--warning-color); font-weight: 600;">Refund: <%= booking.refund_status.toUpperCase() %></span>
                      <% } %>
                    </td>
                    <td style="text-align: right; display: flex; gap: 8px; justify-content: flex-end; align-items: center;">
                      <!-- Download Ticket printable page -->
                      <a href="/user/tickets/<%= booking.booking_id %>" target="_blank" class="btn btn-secondary" style="padding: 6px 12px; font-size: 0.8rem;"><i class="fa-solid fa-print"></i> Print</a>
                      
                      <!-- Refund Request button -->
                      <% if (booking.payment_status === 'paid' && booking.refund_status === 'none') { %>
                        <form action="/user/bookings/<%= booking.booking_id %>/refund" method="POST" style="margin: 0;" onsubmit="return confirm('Are you sure you want to request a refund for this ticket? Organiser will review the request.')">
                          <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 0.8rem; background: rgba(239, 68, 68, 0.15); color: var(--error-color); border: 1px solid rgba(239, 68, 68, 0.2);"><i class="fa-solid fa-reply"></i> Refund</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p style="color: var(--text-muted); text-align: center; padding: 20px;">You haven't booked any tickets yet. Explore upcoming shows!</p>
        <% } %>
      </div>

      <!-- Row: Wishlist & Notifications side-by-side -->
      <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 30px; margin-bottom: 30px;">
        
        <!-- Wishlist Column -->
        <div class="dashboard-card" style="margin-bottom: 0;">
          <h3 class="dashboard-card-title"><i class="fa-solid fa-heart" style="color: #ff2a5f;"></i> Saved Wishlist</h3>
          
          <div style="display: flex; flex-direction: column; gap: 15px; max-height: 350px; overflow-y: auto; padding-right: 5px;">
            <% if (wishlist && wishlist.length > 0) { %>
              <% wishlist.forEach(item => { %>
                <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px; display: flex; justify-content: space-between; align-items: center;">
                  <div>
                    <h4 style="font-size: 0.95rem; font-weight: 600;"><%= item.title %></h4>
                    <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 3px;"><i class="fa-solid fa-location-dot"></i> <%= item.city %></p>
                  </div>
                  <a href="/events/<%= item.id %>" class="btn btn-primary" style="padding: 6px 12px; font-size: 0.8rem;">Book</a>
                </div>
              <% }) %>
            <% } else { %>
              <p style="color: var(--text-muted); font-size: 0.9rem; text-align: center; padding: 20px;">Wishlist is empty.</p>
            <% } %>
          </div>
        </div>

        <!-- Notifications Column -->
        <div class="dashboard-card" style="margin-bottom: 0;">
          <h3 class="dashboard-card-title">
            <span><i class="fa-solid fa-bell" style="color: var(--warning-color);"></i> Recent Notifications</span>
            <% if (notifications.some(n => !n.is_read)) { %>
              <button id="mark-notifications-read" class="btn btn-secondary" style="padding: 4px 10px; font-size: 0.75rem;"><i class="fa-solid fa-check-double"></i> Read All</button>
            <% } %>
          </h3>

          <div style="display: flex; flex-direction: column; gap: 12px; max-height: 350px; overflow-y: auto; padding-right: 5px;">
            <% if (notifications && notifications.length > 0) { %>
              <% notifications.forEach(notif => { %>
                <div style="background: rgba(255,255,255, <%= notif.is_read ? '0.01' : '0.04' %>); border: 1px solid <%= notif.is_read ? 'var(--border-color)' : 'rgba(255, 42, 95, 0.2)' %>; border-radius: 8px; padding: 12px;">
                  <p style="font-size: 0.88rem; color: <%= notif.is_read ? 'var(--text-muted)' : 'var(--text-main)' %>;"><%= notif.message %></p>
                  <p style="font-size: 0.7rem; color: var(--text-muted); margin-top: 5px; text-align: right;"><%= new Date(notif.created_at).toLocaleDateString('en-IN') %></p>
                </div>
              <% }) %>
            <% } else { %>
              <p style="color: var(--text-muted); font-size: 0.9rem; text-align: center; padding: 20px;">No recent notifications.</p>
            <% } %>
          </div>
        </div>

      </div>

      <!-- AI Event Recommendations Grid section (Dynamic Fetch) -->
      <div class="dashboard-card">
        <h3 class="dashboard-card-title">
          <span><i class="fa-solid fa-wand-magic-sparkles" style="background: linear-gradient(135deg, #a855f7 0%, #3b82f6 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i> AI Recommended Events</span>
          <span style="font-size: 0.75rem; color: var(--text-muted); font-weight: normal;">Based on categories you've saved & booked</span>
        </h3>
        
        <!-- Placeholder for recommendations loading -->
        <div id="ai-recommendations-loading" style="text-align: center; padding: 30px; color: var(--text-muted);">
          <i class="fa-solid fa-spinner fa-spin" style="font-size: 1.5rem; margin-bottom: 8px;"></i>
          <p style="font-size: 0.85rem;">Analysing your interests to recommend events...</p>
        </div>

        <div id="ai-recommendations-grid" class="event-grid" style="display: none;">
          <!-- Loaded dynamically via script below -->
        </div>
      </div>

    </div>

  </div>

</main>

<script>
  // Dynamic fetch script for AI event recommendations
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const res = await fetch('/ai/recommendations');
      if (res.ok) {
        const events = await res.json();
        const loader = document.getElementById('ai-recommendations-loading');
        const grid = document.getElementById('ai-recommendations-grid');
        
        if (events && events.length > 0) {
          grid.innerHTML = events.map(event => `
            <div class="event-card" style="font-size: 0.9rem;">
              <div class="event-banner-wrap" style="height: 120px;">
                <span class="event-category-tag" style="font-size: 0.65rem; padding: 2px 6px;">${event.category}</span>
                <img src="${String(event.banner_image).startsWith('data:') ? event.banner_image : '/uploads/' + event.banner_image}" alt="${event.title}" onerror="this.src='https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=300'">
              </div>
              <div class="event-card-body" style="padding: 12px;">
                <h4 style="font-size: 0.95rem; font-weight: 600; margin-bottom: 6px; line-height: 1.2;">${event.title}</h4>
                <p style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 10px;"><i class="fa-solid fa-location-dot" style="color: var(--accent-color);"></i> ${event.city}</p>
                <a href="/events/${event.id}" class="btn btn-primary" style="width: 100%; padding: 6px; font-size: 0.8rem;">Book Ticket</a>
              </div>
            </div>
          `).join('');
          
          loader.style.display = 'none';
          grid.style.display = 'grid';
        } else {
          loader.innerHTML = '<p style="font-size: 0.85rem;">No recommendations available right now. Book more events!</p>';
        }
      }
    } catch (err) {
      console.log('Failed to fetch recommendations:', err);
      document.getElementById('ai-recommendations-loading').style.display = 'none';
    }
  });
</script>

<%- include('../partials/footer') %>
