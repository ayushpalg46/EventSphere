<%- include('../partials/header') %>

<main class="container">
  
  <div class="dashboard-layout">
    
    <!-- Sidebar -->
    <%- include('../partials/sidebar') %>
    
    <!-- Panel Content -->
    <div class="dashboard-content">
      
      <!-- Back button -->
      <a href="/organiser/dashboard" style="color: var(--text-muted); font-size: 0.9rem; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 20px;">
        <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
      </a>

      <!-- Title row -->
      <div class="dashboard-title-row" style="margin-bottom: 10px;">
        <h1>Manage: <%= event.title %></h1>
        <div style="display: flex; gap: 10px;">
          <a href="/organiser/checkin/<%= event.id %>" class="btn btn-primary" style="background: var(--success-color);"><i class="fa-solid fa-qrcode"></i> Open Check-in Panel</a>
        </div>
      </div>
      
      <p style="color: var(--text-muted); margin-bottom: 30px;"><i class="fa-solid fa-location-dot"></i> <%= event.venue_name %>, <%= event.city %> &bull; <i class="fa-solid fa-calendar"></i> <%= new Date(event.start_date).toLocaleDateString('en-IN') %></p>

      <!-- Success & Error Alert boxes -->
      <% if (req.query.payout_success) { %>
        <div class="alert alert-success">
          <i class="fa-solid fa-circle-check"></i> <%= req.query.payout_success %>
        </div>
      <% } %>
      <% if (req.query.payout_error) { %>
        <div class="alert alert-danger">
          <i class="fa-solid fa-circle-exclamation"></i> <%= req.query.payout_error %>
        </div>
      <% } %>

      <!-- Mini Analytics Cards -->
      <div class="stats-row" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
        <div class="stat-card">
          <div class="stat-icon"><i class="fa-solid fa-users"></i></div>
          <div class="stat-details">
            <h3><%= analytics.totalBooked %></h3>
            <p>Total Booked</p>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon"><i class="fa-solid fa-indian-rupee-sign"></i></div>
          <div class="stat-details">
            <h3><%= analytics.totalRevenue %></h3>
            <p>Net Revenue</p>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon"><i class="fa-solid fa-user-check"></i></div>
          <div class="stat-details">
            <h3><%= analytics.totalCheckedIn %></h3>
            <p>Attendees In</p>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon"><i class="fa-solid fa-percentage"></i></div>
          <div class="stat-details">
            <h3>
              <%= analytics.totalBooked > 0 ? Math.round((analytics.totalCheckedIn / analytics.totalBooked) * 100) : 0 %>%
            </h3>
            <p>Check-in Rate</p>
          </div>
        </div>
      </div>

      <!-- Ticket tiers capacities -->
      <div class="dashboard-card">
        <h3 class="dashboard-card-title">Ticket Tiers Releases</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 15px;">
          <% ticketTypes.forEach(t => { %>
            <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 8px; padding: 15px;">
              <h4 style="font-size: 1rem; font-weight: 600;"><%= t.name %></h4>
              <p style="color: var(--text-muted); font-size: 0.85rem; margin-top: 5px;">Price: Rs. <%= t.price %></p>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                <span style="font-size: 0.8rem; font-weight: 500;">Sold: <%= t.sold %> / <%= t.capacity %></span>
                <div style="width: 80px; height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden;">
                  <div style="width: <%= Math.min(100, (t.sold / t.capacity) * 100) %>%; height: 100%; background: var(--accent-gradient);"></div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Registered Attendees List -->
      <div class="dashboard-card">
        <div class="dashboard-card-title">
          <span><i class="fa-solid fa-users-viewfinder" style="color: var(--accent-color);"></i> Attendee Registrations</span>
          <div style="display: flex; gap: 10px;">
            <a href="/organiser/events/<%= event.id %>/export-csv" class="btn btn-secondary" style="padding: 6px 12px; font-size: 0.8rem;"><i class="fa-solid fa-file-csv"></i> Download CSV</a>
          </div>
        </div>

        <% if (attendees && attendees.length > 0) { %>
          <div class="table-responsive">
            <table class="dashboard-table">
              <thead>
                <tr>
                  <th>Ref ID</th>
                  <th>Attendee</th>
                  <th>Contact Info</th>
                  <th>Ticket Tier</th>
                  <th>Qty</th>
                  <th>Paid</th>
                  <th>Check-In</th>
                  <th>Date Booked</th>
                </tr>
              </thead>
              <tbody>
                <% attendees.forEach(att => { %>
                  <tr>
                    <td>#ES-<%= att.booking_id %></td>
                    <td><strong><%= att.name %></strong></td>
                    <td style="font-size: 0.85rem;">
                      <%= att.email %>
                      <br /><span style="color: var(--text-muted);"><%= att.phone || 'No phone' %></span>
                    </td>
                    <td><%= att.ticket_type %></td>
                    <td><%= att.quantity %></td>
                    <td>Rs. <%= att.total_amount %></td>
                    <td>
                      <% if (att.checked_in) { %>
                        <span class="badge badge-paid" style="font-size: 0.7rem;"><i class="fa-solid fa-circle-check"></i> Checked-In</span>
                        <br /><span style="font-size: 0.65rem; color: var(--text-muted);"><%= att.checkin_time %></span>
                      <% } else { %>
                        <span class="badge badge-pending" style="font-size: 0.7rem;"><i class="fa-solid fa-clock"></i> Not Checked-In</span>
                      <% } %>
                    </td>
                    <td style="font-size: 0.8rem; color: var(--text-muted);">
                      <%= new Date(att.booked_at).toLocaleDateString('en-IN') %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p style="color: var(--text-muted); text-align: center; padding: 25px;">No attendee registrations for this event yet.</p>
        <% } %>
      </div>

      <!-- Payout Request Trigger -->
      <div class="dashboard-card" style="border-color: rgba(16, 185, 129, 0.2); background: rgba(16, 185, 129, 0.02);">
        <h3 class="dashboard-card-title" style="color: var(--success-color);"><i class="fa-solid fa-money-bill-transfer"></i> Revenue Payout Sandbox</h3>
        <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 20px;">Once your event starts generating ticket sales, you can request a simulated bank payout directly into your dummy bank account. Gross ticket earnings eligible for transfer: <strong>Rs. <%= analytics.totalRevenue %></strong>.</p>
        
        <form action="/organiser/events/<%= event.id %>/request-payout" method="POST" style="margin: 0;">
          <button type="submit" class="btn btn-primary" style="background: var(--success-color); border-radius: 6px;"><i class="fa-solid fa-file-invoice-dollar"></i> Request Payout (Rs. <%= analytics.totalRevenue %>)</button>
        </form>
      </div>

      <!-- Danger Zone -->
      <div class="dashboard-card" style="border-color: rgba(234, 67, 53, 0.3); background: rgba(234, 67, 53, 0.02); margin-top: 25px;">
        <h3 class="dashboard-card-title" style="color: var(--error-color);"><i class="fa-solid fa-triangle-exclamation"></i> Danger Zone</h3>
        <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 20px;">Deleting this event will permanently remove all ticket types, attendee bookings, payments records, reviews, and event statistics. This action is irreversible.</p>
        
        <form action="/organiser/events/<%= event.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this event? This will permanently delete all associated tickets, bookings, and revenue data. This cannot be undone.');" style="margin: 0;">
          <button type="submit" class="btn btn-danger" style="background: var(--error-color); border-radius: 6px; padding: 10px 20px;"><i class="fa-solid fa-trash-can"></i> Delete Event Listing</button>
        </form>
      </div>

    </div>

  </div>

</main>

<%- include('../partials/footer') %>
