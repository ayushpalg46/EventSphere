        <a href="https://github.com/Tanish210" target="_blank" class="btn btn-secondary" style="padding:8px 16px; font-size:0.82rem; flex:1; justify-content:center;"><i class="fa-brands fa-github"></i> GitHub</a>
        <a href="https://www.linkedin.com/in/tanish-kotian-0337a1394/" target="_blank" class="btn btn-secondary" style="padding:8px 16px; font-size:0.82rem; flex:1; justify-content:center; border-color:rgba(10,102,194,0.3); color:#0A66C2;"><i class="fa-brands fa-linkedin"></i> LinkedIn</a>
        <a href="mailto:tanishkotian3101@gmail.com" class="btn btn-primary" style="padding:8px 16px; font-size:0.82rem; flex:1; justify-content:center;"><i class="fa-solid fa-envelope"></i> Email</a>
      </div>
    </div>

  </div>

  <div class="dashboard-card" style="padding:36px; margin-bottom:32px;">
    <h2 style="font-size:1.2rem; font-weight:700; margin-bottom:6px; display:flex; align-items:center; gap:10px;">
      <i class="fa-solid fa-paper-plane" style="color:#4285F4;"></i> Send a Message
    </h2>
    <p style="color:var(--text-muted); font-size:0.88rem; margin-bottom:24px;">Your message will be logged and both developers will be notified.</p>

    <% if (locals.success) { %>
      <div class="alert alert-success" style="margin-bottom:24px;">
        <i class="fa-solid fa-circle-check"></i> <%= success %>
      </div>
    <% } %>

    <form action="/contact" method="POST">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:18px;">
        <div class="form-group">
          <label for="c-name">Your Name *</label>
          <input type="text" id="c-name" name="name" class="form-control" placeholder="Full name" required>
        </div>
        <div class="form-group">
          <label for="c-email">Email Address *</label>
          <input type="email" id="c-email" name="email" class="form-control" placeholder="you@email.com" required>
        </div>
      </div>
      <div class="form-group" style="margin-top:4px;">
        <label for="c-type">Message Type</label>
        <select id="c-type" name="type" class="form-control">
          <option value="bug">🐛 Bug Report</option>
          <option value="feature">💡 Feature Request</option>
          <option value="collab">🤝 Collaboration</option>
          <option value="other">📬 Other</option>
        </select>
      </div>
      <div class="form-group" style="margin-top:4px;">
        <label for="c-message">Message *</label>
        <textarea id="c-message" name="message" class="form-control" rows="5" placeholder="Describe the issue, idea, or topic in detail..." required></textarea>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%; padding:14px; margin-top:8px;">
        <i class="fa-solid fa-paper-plane"></i> Send Message
      </button>
    </form>
  </div>

  <div class="dashboard-card" style="padding:32px; margin-bottom:32px;">
    <h2 style="font-size:1.1rem; font-weight:700; margin-bottom:20px;"><i class="fa-solid fa-layer-group" style="color:#FBBC04;"></i> &nbsp;Tech Stack</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(130px,1fr)); gap:12px;">
      <% const stack = [
        { label:'Node.js', icon:'fa-node', color:'#34A853' },
        { label:'Express.js', icon:'fa-server', color:'#4285F4' },
        { label:'SQLite / BetterSQLite3', icon:'fa-database', color:'#FBBC04' },
        { label:'EJS Templates', icon:'fa-file-code', color:'#EA4335' },
        { label:'Google Gemini AI', icon:'fa-robot', color:'#4285F4' },
        { label:'Nodemailer', icon:'fa-envelope', color:'#34A853' },
        { label:'bcrypt', icon:'fa-lock', color:'#EA4335' },
        { label:'QR Code Gen', icon:'fa-qrcode', color:'#FBBC04' }
      ] %>
      <% stack.forEach(s => { %>
        <div style="background:rgba(255,255,255,0.03); border:1px solid var(--border-color); border-radius:10px; padding:14px 12px; text-align:center;">
          <i class="fa-solid <%= s.icon %>" style="color:<%= s.color %>; font-size:1.3rem; display:block; margin-bottom:8px;"></i>
          <span style="font-size:0.78rem; color:var(--text-muted); line-height:1.3; display:block;"><%= s.label %></span>
        </div>
      <% }) %>
    </div>
  </div>

  <div style="display:flex; gap:16px; justify-content:center; margin-top:40px; flex-wrap:wrap;">
    <a href="/help" class="btn btn-secondary"><i class="fa-solid fa-headset"></i> Support</a>
    <a href="/docs" class="btn btn-secondary"><i class="fa-solid fa-book-open"></i> Documentation</a>
    <a href="/privacy-policy" class="btn btn-secondary"><i class="fa-solid fa-shield-halved"></i> Privacy Policy</a>
  </div>

</main>

<%- include('../partials/footer') %>
