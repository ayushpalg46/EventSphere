<%- include('../partials/header') %>

<main class="container">
  
  <div style="text-align: center; max-width: 700px; margin: 0 auto 50px auto;">
    <h1 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 12px; background: var(--accent-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Support & Helpline Centre</h1>
    <p style="color: var(--text-muted); font-size: 1.1rem;">Need assistance booking tickets, requesting payouts, or verifying entry? Browse our FAQs or file a ticket below.</p>
  </div>

  <% if (success) { %>
    <div class="alert alert-success" style="max-width: 800px; margin: 0 auto 30px auto;">
      <i class="fa-solid fa-circle-check"></i> <%= success %>
    </div>
  <% } %>

  <div style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 40px; max-width: 1000px; margin: 0 auto;">
    
    <!-- Left Column: Support FAQs -->
    <div>
      <h2 style="font-size: 1.5rem; margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">Frequently Asked Questions</h2>
      
      <details class="faq-item" open>
        <summary>How do I show my ticket at entry?</summary>
        <div class="faq-answer">
          <p>Login to EventSphere on your mobile phone, navigate to <strong>My Dashboard</strong>, and open the ticket QR code. Show this QR code to the event organiser at the entry desk for scanning.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary>What is the ticket refund policy?</summary>
        <div class="faq-answer">
          <p>Refund rules are set by individual event organisers. You can request a refund directly from your attendee dashboard bookings list. Once requested, the organiser will review and approve/reject it.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary>I am an organiser. How do I withdraw my earnings?</summary>
        <div class="faq-answer">
          <p>Go to your organiser dashboard, click "Manage" on the specific event, and look at the bottom section for <strong>Revenue Payout Sandbox</strong>. Click the "Request Payout" button to simulate a wire transfer.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary>How does the AI Description Generator work?</summary>
        <div class="faq-answer">
          <p>When creating an event, look at the AI Description Assistant container. Input bullet points of details, and it will use Google Gemini API to draft a professional HTML-formatted description automatically.</p>
        </div>
      </details>
    </div>

    <!-- Right Column: Contact Form -->
    <div>
      <div class="dashboard-card" style="margin: 0; padding: 30px;">
        <h2 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 20px;"><i class="fa-solid fa-envelope-open-text" style="color: var(--accent-color);"></i> File a Support Ticket</h2>
        
        <form action="/help" method="POST">
          <div class="form-group">
            <label for="help-name">Full Name *</label>
            <input type="text" id="help-name" name="name" class="form-control" placeholder="Enter name" required>
          </div>

          <div class="form-group">
            <label for="help-email">Email Address *</label>
            <input type="email" id="help-email" name="email" class="form-control" placeholder="email@example.com" required>
          </div>

          <div class="form-group">
            <label for="help-subject">Subject Subject *</label>
            <input type="text" id="help-subject" name="query_subject" class="form-control" placeholder="Booking issue, Organiser help..." required>
          </div>

          <div class="form-group">
            <label for="help-message">Query Message *</label>
            <textarea id="help-message" name="message" class="form-control" placeholder="Describe your issue in detail..." required></textarea>
          </div>

          <button type="submit" class="btn btn-primary" style="width: 100%; padding: 12px; margin-top: 10px;">
            Submit Support Request <i class="fa-solid fa-paper-plane"></i>
          </button>
        </form>
      </div>
    </div>

  </div>

</main>

<%- include('../partials/footer') %>
