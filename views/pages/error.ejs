<%- include('../partials/header') %>

<main class="container">
  <div class="form-card" style="max-width: 550px; text-align: center; padding: 40px;">
    <div style="font-size: 4rem; color: var(--accent-color); margin-bottom: 20px;">
      <i class="fa-solid fa-circle-exclamation"></i>
    </div>
    
    <h2 class="form-title" style="margin-bottom: 10px;"><%= title || 'Access Denied' %></h2>
    <p style="color: var(--text-muted); font-size: 1.05rem; line-height: 1.6; margin-bottom: 30px;">
      <%= message || 'You do not have permission to access this page.' %>
    </p>

    <div style="display: flex; flex-direction: column; gap: 12px;">
      <% if (user) { %>
        <% if (user.role === 'organiser') { %>
          <a href="/organiser/dashboard" class="btn btn-primary" style="padding: 12px;"><i class="fa-solid fa-gauge"></i> Go to Organiser Panel</a>
        <% } else { %>
          <a href="/user/dashboard" class="btn btn-primary" style="padding: 12px;"><i class="fa-solid fa-table-list"></i> Go to Attendee Dashboard</a>
        <% } %>
      <% } %>
      <a href="/" class="btn btn-secondary" style="padding: 12px;"><i class="fa-solid fa-house"></i> Return to Homepage</a>
      
      <% if (user) { %>
        <div style="border-top: 1px solid var(--border-color); margin-top: 20px; padding-top: 20px;">
          <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 10px;">Logged in as <strong><%= user.email %></strong> (<%= user.role %>)</p>
          <a href="/logout" class="btn btn-danger" style="background: rgba(ef, 68, 68, 0.1); border-color: rgba(ef, 68, 68, 0.2); color: #ef4444; padding: 10px; font-size: 0.85rem; width: 100%;">
            <i class="fa-solid fa-right-from-bracket"></i> Logout & Switch Account
          </a>
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
