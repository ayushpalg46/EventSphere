<%- include('../partials/header') %>

<!-- Top Banner Area -->
<section class="detail-banner">
  <%
    let fallbackImage = 'https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?w=1000';
    if (event.category === 'Music') fallbackImage = 'https://images.unsplash.com/photo-1506157786151-b8491531f063?w=1000';
    else if (event.category === 'Comedy') fallbackImage = 'https://images.unsplash.com/photo-1585647347483-22b66260dfff?w=1000';
    else if (event.category === 'Tech') fallbackImage = 'https://images.unsplash.com/photo-1515879218367-8466d910aaa4?w=1000';
    else if (event.category === 'Movies') fallbackImage = 'https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=1000';
  %>
  <img src="<%= String(event.banner_image).startsWith('data:') ? event.banner_image : '/uploads/' + event.banner_image %>" alt="<%= event.title %>" onerror="this.src='<%= fallbackImage %>'">
</section>

<main class="container" style="margin-top: 0; padding-top: 0;">
  
  <!-- Floating Header Card -->
  <div class="detail-header-card">
    <div class="detail-title-area">
      <span class="event-category-tag" style="position: static; display: inline-block; margin-bottom: 12px;"><%= event.category %></span>
      <h1><%= event.title %></h1>
      
      <div class="detail-meta-grid">
        <div class="detail-meta-item">
          <i class="fa-solid fa-calendar-day"></i>
          <span><%= new Date(event.start_date).toLocaleString('en-IN', { weekday: 'short', day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
        </div>
        <div class="detail-meta-item">
          <i class="fa-solid fa-location-dot"></i>
          <span><%= event.venue_name %>, <%= event.city %></span>
        </div>
        <% if (avgRating > 0) { %>
          <div class="detail-meta-item">
            <i class="fa-solid fa-star" style="color: var(--warning-color);"></i>
            <span><%= avgRating %> / 5.0 Rating</span>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Booking CTA Buttons -->
    <div style="display: flex; flex-direction: column; gap: 10px; align-items: flex-end;">
      <% if (event.status === 'upcoming') { %>
        <a href="/booking/<%= event.id %>" class="btn btn-primary" style="padding: 15px 30px; font-size: 1.1rem;"><i class="fa-solid fa-ticket"></i> Book Tickets Now</a>
      <% } else { %>
        <button class="btn btn-secondary" disabled style="padding: 15px 30px;"><%= event.status.toUpperCase() %></button>
      <% } %>
      
      <button class="wishlist-toggle-btn btn btn-secondary <%= isWishlisted ? 'active' : '' %>" data-event-id="<%= event.id %>" style="<%= isWishlisted ? 'color: #ff2a5f;' : '' %>">
        <i class="<%= isWishlisted ? 'fa-solid' : 'fa-regular' %> fa-heart"></i> 
        <%= isWishlisted ? 'Wishlisted' : 'Add to Wishlist' %>
      </button>
    </div>
  </div>

  <!-- Layout: 2 Columns -->
  <div class="detail-grid">
    
    <!-- Left Column: Details -->
    <div>
      <div class="detail-section">
        <h2>About the Event</h2>
        <div style="line-height: 1.8; color: var(--text-muted);">
          <!-- EJS raw output for AI-generated HTML descriptions -->
          <%- event.description %>
        </div>
      </div>

      <% if (event.agendaList && event.agendaList.length > 0) { %>
        <div class="detail-section">
          <h2>Event Agenda & Schedule</h2>
          <div class="timeline">
            <% event.agendaList.forEach(session => { %>
              <div class="timeline-item">
                <p class="timeline-time"><%= session.time %></p>
                <h4 class="timeline-title"><%= session.title %></h4>
                <% if (session.speaker) { %>
                  <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 3px;">Speaker: <%= session.speaker %></p>
                <% } %>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <% if (event.speakersList && event.speakersList.length > 0) { %>
        <div class="detail-section">
          <h2>Speakers & Host</h2>
          <div class="speakers-grid">
            <% event.speakersList.forEach(speaker => { %>
              <div class="speaker-card" data-tilt data-tilt-scale="1.04">
                <div class="speaker-avatar">
                  <%= speaker.name.charAt(0) %>
                </div>
                <h4><%= speaker.name %></h4>
                <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 5px;"><%= speaker.designation %></p>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <% if (event.faqList && event.faqList.length > 0) { %>
        <div class="detail-section">
          <h2>Frequently Asked Questions</h2>
          <% event.faqList.forEach(item => { %>
            <details class="faq-item">
              <summary><%= item.q %></summary>
              <div class="faq-answer">
                <p><%= item.a %></p>
              </div>
            </details>
          <% }) %>
        </div>
      <% } %>

      <!-- Community Reviews and Ratings Section -->
      <div class="detail-section">
        <h2>Attendee Reviews (<%= reviews.length %>)</h2>

        <!-- Leave a Review Form -->
        <% if (user) { %>
          <div class="dashboard-card" style="margin-bottom: 30px; padding: 20px;">
            <h3 style="font-size: 1.1rem; margin-bottom: 15px;">Rate & Review this Event</h3>
            
            <form action="/events/<%= event.id %>/review" method="POST">
              <div class="form-group" style="display: flex; align-items: center; gap: 15px;">
                <label style="margin-bottom: 0;">Your Rating:</label>
                <div class="stars-input" style="display: flex; gap: 8px;">
                  <select name="rating" class="form-control" style="width: auto; padding: 5px 10px; background: var(--bg-secondary); color: white;" required>
                    <option value="5">⭐⭐⭐⭐⭐ (5 Star)</option>
                    <option value="4">⭐⭐⭐⭐ (4 Star)</option>
                    <option value="3">⭐⭐⭐ (3 Star)</option>
                    <option value="2">⭐⭐ (2 Star)</option>
                    <option value="1">⭐ (1 Star)</option>
                  </select>
                </div>
              </div>
              
              <div class="form-group">
                <textarea name="comment" class="form-control" placeholder="Share your experience or expectations about this event..." rows="3"></textarea>
              </div>
              
              <button type="submit" class="btn btn-primary" style="padding: 8px 20px; font-size: 0.9rem;">Submit Review</button>
            </form>
          </div>
        <% } else { %>
          <p style="background: rgba(255,255,255,0.02); padding: 15px; border-radius: 8px; border: 1px solid var(--border-color); font-size: 0.9rem; margin-bottom: 30px;">
            Please <a href="/login" style="color: var(--accent-color); font-weight: 600;">login</a> to write a review.
          </p>
        <% } %>

        <!-- Reviews List -->
        <div class="reviews-list">
          <% if (reviews && reviews.length > 0) { %>
            <% reviews.forEach(review => { %>
              <div class="review-item">
                <div class="review-header">
                  <div>
                    <span class="review-user"><%= review.user_name %></span>
                    <span class="stars" style="margin-left: 10px;">
                      <% for(let i=0; i<review.rating; i++) { %>★<% } %>
                    </span>
                  </div>
                  <span class="review-date"><%= new Date(review.created_at).toLocaleDateString('en-IN') %></span>
                </div>
                <p class="review-comment"><%= review.comment || 'No written comment left.' %></p>
              </div>
            <% }) %>
          <% } else { %>
            <p style="color: var(--text-muted); font-size: 0.9rem;">No reviews yet. Be the first to share your thoughts!</p>
          <% } %>
        </div>
      </div>

    </div>

    <!-- Right Column: Sidebar Details -->
    <div>
      <div class="dashboard-card" style="position: sticky; top: 100px;">
        <h3 class="dashboard-card-title" style="border-bottom: 1px solid var(--border-color); padding-bottom: 10px; margin-bottom: 15px;">Event Info</h3>
        
        <div style="display: flex; flex-direction: column; gap: 15px; font-size: 0.95rem;">
          <div>
            <p style="color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; font-weight: 600;">Event Venue</p>
            <% if (event.is_online === 1) { %>
              <div style="background: rgba(168, 85, 247, 0.08); border: 1px solid rgba(168, 85, 247, 0.2); border-radius: 14px; padding: 20px; margin-top: 10px; text-align: center; box-shadow: 0 4px 15px rgba(0,0,0,0.15);">
                <i class="fa-solid fa-video" style="font-size: 2.2rem; color: #a855f7; margin-bottom: 12px;"></i>
                <h4 style="font-weight: 700; color: white; margin-bottom: 5px;">Virtual Event (Online)</h4>
                <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.5;">This event is fully virtual. The access link will be available on your tickets dashboard after successful registration.</p>
              </div>
            <% } else { %>
              <p style="font-weight: 500; margin-top: 3px;"><%= event.venue_name %></p>
              <p style="color: var(--text-muted); font-size: 0.85rem;"><%= event.venue_address %></p>
              <!-- Real Google Map Embed -->
              <div style="width: 100%; height: 200px; border-radius: 14px; margin-top: 12px; overflow: hidden; border: 1px solid var(--border-color); box-shadow: 0 4px 15px rgba(0,0,0,0.25);">
                <% 
                  const mapQueryParts = [];
                  if (event.venue_name) mapQueryParts.push(event.venue_name);
                  if (event.venue_address) mapQueryParts.push(event.venue_address);
                  if (event.city) mapQueryParts.push(event.city);
                  const cleanMapQuery = mapQueryParts.join(', ');
                %>
                <iframe 
                  width="100%" 
                  height="100%" 
                  frameborder="0" 
                  style="border:0;" 
                  src="https://maps.google.com/maps?q=<%= encodeURIComponent(cleanMapQuery) %>&t=&z=14&ie=UTF8&iwloc=&output=embed" 
                  allowfullscreen
                  loading="lazy">
                </iframe>
              </div>
            <% } %>
          </div>

          <hr style="border: 0.5px solid var(--border-color);" />

          <div>
            <p style="color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; font-weight: 600;">Organised By</p>
            <p style="font-weight: 600; margin-top: 3px; color: var(--text-main);"><%= event.organiser_name %></p>
          </div>

          <!-- Attendee Networking LinkedIn Box -->
          <% if (networkingUsers && networkingUsers.length > 0) { %>
            <hr style="border: 0.5px solid var(--border-color);" />
            <div>
              <p style="color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; font-weight: 600; margin-bottom: 10px;">Attendee Networking</p>
              <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 10px;">Connect with other attendees of this event on LinkedIn:</p>
              
              <div style="display: flex; flex-direction: column; gap: 8px;">
                <% networkingUsers.forEach(netUser => { %>
                  <a href="<%= netUser.linkedin_url %>" target="_blank" class="btn btn-secondary" style="justify-content: flex-start; padding: 6px 12px; font-size: 0.85rem; background: rgba(0, 119, 181, 0.08); border-color: rgba(0, 119, 181, 0.2);">
                    <i class="fa-brands fa-linkedin" style="color: #0077b5;"></i> <%= netUser.name %>
                  </a>
                <% }) %>
              </div>
            </div>
          <% } %>

        </div>
      </div>
    </div>

  </div>

</main>

<%- include('../partials/footer') %>
